{
  "name": "@repo/db",
  "version": "1.0.0",
  "description": "DB Package - PostgreSQL/Drizzle ORM",
  "type": "module",
  "scripts": {
    "lint": "FORCE_COLOR=1 eslint src/",
    "build": "tsup",
    "type-check": "tsc --noEmit",
    "db:generate": "pnpm exec drizzle-kit generate --config=drizzle.config.local.ts",
    "db:migrate": "pnpm exec drizzle-kit migrate --config=drizzle.config.local.ts",
    "db:custom": "pnpm exec drizzle-kit generate --custom --config=drizzle.config.local.ts",
    "db:generate:deploy": "pnpm exec drizzle-kit generate --config=drizzle.config.deploy.ts",
    "db:migrate:deploy": "pnpm exec drizzle-kit migrate --config=drizzle.config.deploy.ts",
    "db:custom:deploy": "pnpm exec drizzle-kit generate --custom --config=drizzle.config.deploy.ts",
    "db:seed": "tsx src/seed/index.ts"
  },
  "exports": {
    ".": {
      "volume-seven": "./src/index.ts",
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "dotenv": "^17.2.3",
    "drizzle-kit": "^0.31.8",
    "drizzle-orm": "^0.45.1",
    "drizzle-zod": "^0.8.3",
    "pg": "^8.16.3",
    "zod": "^4.2.0"
  },
  "devDependencies": {
    "@repo/config-eslint-custom": "workspace:*",
    "@repo/config-typescript": "workspace:*",
    "@types/pg": "^8.16.0",
    "@typescript-eslint/eslint-plugin": "^8.50.0",
    "tsx": "^4.21.0"
  }
}
