{
  "name": "the-franklin-project",
  "private": true,
  "packageManager": "pnpm@10.26.0",
  "engines": {
    "node": ">=23"
  },
  "scripts": {
    "dev": "turbo dev",
    "dev:app": "turbo dev --filter={@repo/backend,@repo/frontend,@repo/worker}",
    "dev:backend": "turbo dev --filter=@repo/backend",
    "dev:frontend": "turbo dev --filter={@repo/frontend,@repo/ui}",
    "dev:worker": "turbo dev --filter=@repo/worker",
    "build": "turbo build",
    "build:backend": "turbo build --filter=@repo/backend",
    "build:frontend": "turbo build --filter={@repo/frontend,@repo/ui}",
    "build:worker": "turbo build --filter=@repo/worker",
    "lint": "turbo lint -- --no-warn-ignored",
    "type-check": "turbo type-check",
    "test": "turbo test",
    "clean": "turbo clean",
    "nuke": "rm -rf node_modules **/node_modules",
    "rebirth": "pnpm nuke && pnpm i",
    "format": "prettier --write \"**/*.{js,cjs,mjs,ts,tsx,md}\"",
    "prepare": "husky",
    "add-shadcn-component": "turbo run add-shadcn-component -- --",
    "db:pull": "dotenv -- turbo db:pull --filter=@repo/db",
    "db:generate": "dotenv -- turbo db:generate --filter=@repo/db",
    "db:migrate": "dotenv -- turbo db:migrate --filter=@repo/db",
    "db:generate:deploy": "dotenv -- turbo db:generate:deploy --filter=@repo/db",
    "db:migrate:deploy": "pnpm --filter=@repo/db exec drizzle-kit migrate --config=drizzle.config.deploy.ts",
    "db:index:mviews": "dotenv -- tsx --conditions=volume-seven  ./apps/backend/src/scripts/indexes/drop-and-create-unique-idx-mviews.ts",
    "db:seed:mock:users": "dotenv -- tsx --conditions=volume-seven  ./apps/backend/src/scripts/data/mock/users.ts",
    "db:dev:godmode": "dotenv -- tsx --conditions=volume-seven  ./apps/backend/src/scripts/data/permissions/dev-superadmin.ts",
    "pull:master": "git stash && git checkout master && git pull && pnpm i && cd packages/db && pnpm db:generate && pnpm db:migrate"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/vite": "^4.1.18",
    "eslint": "^9.39.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.7.4",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "turbo": "^2.6.3"
  },
  "dependencies": {
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "dotenv": "^17.2.3",
    "dotenv-cli": "^11.0.0",
    "drizzle-orm": "^0.45.1",
    "typescript": "5.9.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "pnpm lint",
      "pnpm format"
    ]
  }
}
