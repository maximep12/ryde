# Environment
ENV=LOCAL

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres

# Redis
REDIS_URL=redis://localhost:6379

# S3 (LocalStack for local dev — set S3_ENDPOINT to use LocalStack, unset for real AWS)
S3_ENDPOINT=http://localhost:4566
S3_ACCESS_KEY_ID=test
S3_SECRET_ACCESS_KEY=test
S3_BUCKET_NAME=ryde-local
S3_REGION=us-east-1
S3_ENV=qa
