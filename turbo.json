{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**", "build/**"],
      "passThroughEnv": ["VITE_FRONTEND_SENTRY_DSN", "VITE_SENTRY_AUTH_TOKEN", "SENTRY_AUTH_TOKEN"]
    },
    "lint": {},
    "type-check": {},
    "test": {},
    "dev": {
      "cache": false,
      "persistent": true
    },
    "clean": {
      "cache": false
    },
    "add-shadcn-component": {
      "cache": false,
      "interactive": true
    },
    "db:generate": {},
    "db:migrate": {},
    "db:pull": {},
    "db:generate:deploy": {},
    "db:migrate:deploy": {}
  }
}
