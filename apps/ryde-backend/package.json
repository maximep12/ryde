{
  "name": "ryde",
  "version": "1.0.0",
  "description": "",
  "author": "",
  "scripts": {
    "build": "babel src -d dist",
    "start": "NODE_ENV=production knex migrate:latest && node dist",
    "dev": "nodemon --exec babel-node src/index.js",
    "lint": "eslint 'src/**/*.js'",
    "prettier": "prettier --write 'src/**/*.js'",
    "db:migrate": "knex migrate:latest",
    "worker": "node bin/worker.js"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "src/**/*.js": [
      "prettier --write",
      "eslint",
      "git add"
    ]
  },
  "engines": {
    "node": "22.18.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.449.0",
    "@aws-sdk/lib-storage": "^3.513.0",
    "@azure/storage-blob": "^12.17.0",
    "@babel/cli": "^7.22.15",
    "@babel/core": "^7.23.6",
    "@babel/eslint-parser": "^7.22.15",
    "@babel/node": "^7.22.15",
    "@babel/plugin-proposal-class-properties": "^7.18.6",
    "@babel/preset-env": "^7.22.15",
    "@babel/register": "^7.22.15",
    "@koa/cors": "^5.0.0",
    "@koa/router": "^14.0.0",
    "aws-sdk": "^2.1493.0",
    "axios": "^1.6.7",
    "babel-plugin-module-resolver": "^5.0.0",
    "babel-polyfill": "^6.26.0",
    "bcrypt": "^5.1.1",
    "bluebird": "^3.7.2",
    "bull": "^4.11.5",
    "core-js": "^3.36.0",
    "csv-parse": "^5.5.0",
    "dotenv": "^16.3.1",
    "eslint-plugin-n": "^16.0.2",
    "exceljs": "^4.4.0",
    "faker": "^5.5.3",
    "glob": "^10.3.4",
    "husky": "^8.0.3",
    "jsonwebtoken": "^9.0.2",
    "jszip": "^3.10.1",
    "knex": "^2.5.1",
    "knex-cleaner": "^1.3.1",
    "koa": "^3.0.1",
    "koa-bodyparser": "^4.4.1",
    "koa-compress": "^5.1.1",
    "koa-convert": "^2.0.0",
    "koa-cors": "^0.0.16",
    "koa-json-logger": "^1.0.2",
    "koa-logger": "^3.2.1",
    "koa-passport": "^6.0.0",
    "lint-staged": "^14.0.1",
    "lodash": "^4.17.21",
    "moment": "^2.29.4",
    "objection": "^3.1.1",
    "passport-local": "^1.0.0",
    "pg": "^8.11.3",
    "pg-copy-streams": "^6.0.6",
    "prettier": "^3.0.3",
    "zip-state": "^1.0.3"
  },
  "devDependencies": {
    "eslint": "^8.49.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-config-standard": "^17.1.0",
    "eslint-import-resolver-babel-module": "^5.3.2",
    "eslint-plugin-babel": "^5.3.1",
    "eslint-plugin-import": "^2.28.1",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-promise": "^6.1.1",
    "nodemon": "^3.0.1"
