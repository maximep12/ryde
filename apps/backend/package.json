{
  "name": "@repo/backend",
  "type": "module",
  "version": "1.0.0",
  "exports": {
    "./app": "./src/index.ts"
  },
  "description": "Backend - Hono API server with TypeScript, PostgreSQL/Drizzle ORM, Redis, JWT auth",
  "scripts": {
    "dev": "NODE_OPTIONS='--inspect' tsx watch --conditions=volume-seven src/index.ts",
    "build": "tsup",
    "lint": "FORCE_COLOR=1 eslint src/",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "start": "pnpm -w db:migrate:deploy && node dist"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.972.0",
    "@aws-sdk/s3-request-presigner": "^3.972.0",
    "@azure/storage-blob": "^12.17.0",
    "@hono/node-server": "^1.19.7",
    "@hono/zod-validator": "^0.7.5",
    "@repo/config-eslint-custom": "workspace:*",
    "@repo/config-typescript": "workspace:*",
    "@repo/constants": "workspace:*",
    "@repo/csv": "workspace:*",
    "@repo/db": "workspace:*",
    "@repo/zod-schemas": "workspace:*",
    "@repo/logger": "workspace:*",
    "@repo/redis": "workspace:*",
    "@types/bcrypt": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/jszip": "^3.4.1",
    "@types/ssh2-sftp-client": "^9.0.0",
    "axios": "^1.13.2",
    "bcrypt": "^5.1.1",
    "bull": "^4.11.5",
    "csv-parse": "^5.5.0",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.1",
    "exceljs": "^4.4.0",
    "hono": "^4.11.1",
    "ioredis": "^5.8.2",
    "jsonwebtoken": "^9.0.3",
    "jszip": "^3.10.1",
    "lodash": "^4.17.21",
    "pg": "^8.16.3",
    "resend": "^6.9.4",
    "ssh2-sftp-client": "^11.0.0",
    "zip-state": "^1.0.3",
    "zod": "^4.2.0"
  },
  "devDependencies": {
    "@types/lodash": "^4.17.0",
    "@types/node": "^25.0.2",
    "@types/pg": "^8.16.0",
    "drizzle-kit": "^0.31.8",
    "tsx": "^4.21.0",
    "vite": "^7.3.0",
    "vite-tsconfig-paths": "^6.0.1",
    "vitest": "^4.0.15"
  }
}
