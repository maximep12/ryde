{
  "name": "@repo/backend",
  "type": "module",
  "version": "1.0.0",
  "description": "Backend - Hono API server with TypeScript, PostgreSQL/Drizzle ORM, Redis",
  "scripts": {
    "dev": "NODE_OPTIONS='--inspect' tsx watch --conditions=volume-seven src/index.ts",
    "build": "tsup && pnpm sentry:sourcemaps",
    "lint": "FORCE_COLOR=1 eslint src/",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "start": "pnpm -w db:migrate:deploy && pnpm -w db:seed:roles && node dist",
    "sentry:sourcemaps": "sentry-cli sourcemaps inject --org volume7 --project placeholder-backend ./dist && sentry-cli sourcemaps upload --org volume7 --project placeholder-backend ./dist"
  },
  "exports": {
    "./app": "./src/index.ts",
    "./comments": "./src/routers/comments/index.ts",
    "./users": "./src/routers/users/index.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.7",
    "@hono/zod-validator": "^0.7.5",
    "@repo/config-eslint-custom": "workspace:*",
    "@repo/config-sentry": "workspace:*",
    "@repo/config-typescript": "workspace:*",
    "@repo/constants": "workspace:*",
    "@repo/db": "workspace:*",
    "@repo/feature-flags": "workspace:*",
    "@repo/logger": "workspace:*",
    "@repo/queue": "workspace:*",
    "@repo/redis": "workspace:*",
    "@repo/utils": "workspace:*",
    "@repo/zod-schemas": "workspace:*",
    "@sentry/cli": "^3.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "axios": "^1.13.2",
    "bluebird": "^3.7.2",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.11.1",
    "ioredis": "^5.8.2",
    "jsonwebtoken": "^9.0.3",
    "luxon": "^3.7.2",
    "pg": "^8.16.3",
    "zod": "^4.2.0"
  },
  "devDependencies": {
    "@types/bluebird": "^3.5.42",
    "@types/node": "^25.0.2",
    "@types/pg": "^8.16.0",
    "drizzle-kit": "^0.31.8",
    "tsx": "^4.21.0",
    "vite": "^7.3.0",
    "vite-tsconfig-paths": "^6.0.1",
    "vitest": "^4.0.15"
  }
}
